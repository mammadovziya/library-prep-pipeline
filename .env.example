# Every production image value must be an immutable name@sha256:digest reference.
POSTGRES_IMAGE=registry.internal/library-prep-postgres:18.4@sha256:REPLACE_AFTER_BUILD
NATS_IMAGE=nats:2.14.0-alpine@sha256:REPLACE_AFTER_QUALIFICATION
CADDY_IMAGE=caddy:2.11.4-alpine@sha256:REPLACE_AFTER_QUALIFICATION
AUTHENTIK_IMAGE=ghcr.io/goauthentik/server:2026.5.2@sha256:REPLACE_AFTER_QUALIFICATION
SEAWEEDFS_IMAGE=chrislusf/seaweedfs:4.29@sha256:REPLACE_AFTER_QUALIFICATION
PROMETHEUS_IMAGE=prom/prometheus:v3.12.0@sha256:REPLACE_AFTER_QUALIFICATION
BLACKBOX_EXPORTER_IMAGE=quay.io/prometheus/blackbox-exporter:v0.28.0@sha256:REPLACE_AFTER_QUALIFICATION
NODE_EXPORTER_IMAGE=quay.io/prometheus/node-exporter:v1.11.1@sha256:REPLACE_AFTER_QUALIFICATION
API_IMAGE=registry.internal/library-prep-api@sha256:REPLACE_AFTER_BUILD
SCHEDULER_IMAGE=registry.internal/library-prep-scheduler@sha256:REPLACE_AFTER_BUILD
GC_IMAGE=registry.internal/library-prep-gc@sha256:REPLACE_AFTER_BUILD
STORAGE_INIT_IMAGE=registry.internal/library-prep-storage-init@sha256:REPLACE_AFTER_BUILD
AGENT_IMAGE=registry.internal/library-prep-agent@sha256:REPLACE_AFTER_BUILD
WEB_IMAGE=registry.internal/library-prep-web@sha256:REPLACE_AFTER_BUILD
CHEMISTRY_IMAGE_DIGEST=registry.internal/library-prep-chemistry@sha256:REPLACE_AFTER_QUALIFICATION

APP_DOMAIN=app.example.org
AUTH_DOMAIN=auth.example.org
OBJECTS_DOMAIN=objects.example.org
POSTGRES_PASSWORD=replace-with-ansible-vault-secret
AUTHENTIK_DB_PASSWORD=replace-with-ansible-vault-secret
SEAWEED_FILER_DB_PASSWORD=replace-with-ansible-vault-secret
AUTHENTIK_SECRET_KEY=replace-with-ansible-vault-secret
AUTHENTIK_BOOTSTRAP_PASSWORD=replace-with-ansible-vault-secret
OIDC_CLIENT_ID=library-prep-web
OIDC_CLIENT_SECRET=replace-with-ansible-vault-secret
SESSION_SECRET=replace-with-at-least-32-random-characters
S3_ACCESS_KEY_ID=replace-with-per-service-key
S3_SECRET_ACCESS_KEY=replace-with-per-service-secret

# Storage-host examples. Ansible replaces these per host.
STORAGE_INTERNAL_IP=10.77.0.11
STORAGE_NODE_NAME=storage-a
STORAGE_MASTER_PATH=/srv/seaweed/master
STORAGE_VOLUME_PATH=/srv/seaweed/volume
STORAGE_MAX_VOLUMES=26

# Worker-host examples. Ansible replaces these per host.
WORKER_INTERNAL_IP=10.77.0.20
GPU_UUID=GPU-REPLACE-WITH-NVIDIA-UUID
