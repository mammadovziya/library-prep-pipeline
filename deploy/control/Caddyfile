{
	email {$ACME_EMAIL}
	servers {
		protocols h1 h2
	}
}

(security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "same-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}
}

{$APP_DOMAIN} {
	import security_headers
	encode zstd gzip
	reverse_proxy web:3000
}

{$AUTH_DOMAIN} {
	import security_headers
	reverse_proxy authentik-server:9000
}

{$OBJECTS_DOMAIN} {
	import security_headers
	request_body {
		max_size 20GB
	}
	reverse_proxy https://storage-a.internal:443 https://storage-b.internal:443 {
		lb_policy least_conn
		# An unauthenticated S3 service-root request must be rejected while the
		# gateway is healthy; this also catches accidental auth disablement.
		health_uri /
		health_status 403
		health_interval 10s
		fail_duration 30s
		flush_interval -1
		transport http {
			tls_server_name storage.internal
			tls_trust_pool file /etc/library-prep/pki/ca.crt
			tls_client_auth /etc/library-prep/pki/caddy.crt /etc/library-prep/pki/caddy.key
			dial_timeout 5s
			response_header_timeout 30s
		}
	}
}
