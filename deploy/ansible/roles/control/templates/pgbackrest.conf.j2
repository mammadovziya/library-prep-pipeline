[global]
repo1-host=storage-b.internal
repo1-host-user=pgbackrest
repo1-path=/var/lib/pgbackrest/repo1
repo1-retention-full=2
repo1-retention-diff=14
repo1-cipher-type=aes-256-cbc
repo1-cipher-pass={{ vault_pgbackrest_repo1_cipher_pass }}
repo2-host=storage-c.internal
repo2-host-user=pgbackrest
repo2-path=/var/lib/pgbackrest/repo2
repo2-retention-full=2
repo2-retention-diff=14
repo2-cipher-type=aes-256-cbc
repo2-cipher-pass={{ vault_pgbackrest_repo2_cipher_pass }}
archive-async=y
archive-timeout=240
spool-path=/var/spool/pgbackrest
process-max=4
start-fast=y

[library-prep]
pg1-path=/var/lib/postgresql/data
pg1-port=5432
pg1-user=library_prep
